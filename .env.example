# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_USER=sirius
POSTGRES_PASSWORD=changeme
POSTGRES_DB=sirius27
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://sirius:changeme@db:5432/sirius27

# ── Vault role (isolated schema for keys & pseudonym map) ──
VAULT_ROLE_PASSWORD=changeme_vault

# ── Redis ──────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ── Redis Streams ──────────────────────────────────────────
STREAM_NAME=jobs:stream
CONSUMER_GROUP=worker-group
CONSUMER_NAME=worker-1

# ── Backend (FastAPI) ──────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
SECRET_KEY=change-me-to-a-random-secret

# ── Auth / JWT ─────────────────────────────────────────────
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Bootstrap admin (created on startup if both are set) ───
BOOTSTRAP_ADMIN_EMAIL=admin@sirius27.local
BOOTSTRAP_ADMIN_PASSWORD=changeme_admin

# ── Demo seed (fills the learning portals; idempotent) ─────
# Provisions teacher/child/parent demo accounts and learning data on startup.
SEED_DEMO=true
SEED_DEMO_PASSWORD=demo12345

# ── Frontend (Next.js) ─────────────────────────────────────
NEXT_PUBLIC_API_URL=/api
BACKEND_URL=http://backend:8000
